<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>KDrama - Home</title>
</head>
<body>
    <header>
        <h1>Welcome to KDramas</h1>
        <nav>
            <ul>
                <li><a href="/">Home</a></li>
                <li><a href="/shows">Shows</a></li>
            </ul>
        </nav>
    </header>
    <main>
        <h2>Featured Shows</h2>
        <div id="shows-list">
            <% if (shows && shows.length) { %>
                <ul>
                    <% shows.forEach(show => { %>
                        <li>
                            <a href="/shows/<%= show.id %>"><%= show.title %></a> - <%= show.genre %>
                        </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <p>No shows available at the moment.</p>
            <% } %>
        </div>
    </main>
    <footer>
        <p>&copy; 2023 KDramas. All rights reserved.</p>
    </footer>
    <script src="/js/main.js"></script>
</body>
</html>